{
  "name": "@sprintjam/retro-worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./src/index.ts",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b --noEmit",
    "generate:types": "wrangler types --include-runtime=false"
  },
  "dependencies": {
    "@sentry/cloudflare": "^10.52.0",
    "@sprintjam/types": "workspace:*",
    "@sprintjam/utils": "workspace:*"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "4.20260115.0",
    "typescript": "5.9.3",
    "vitest": "4.0.16",
    "wrangler": "4.87.0"
  }
}
