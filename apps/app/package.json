{
  "name": "@sprintjam/app",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "./api/index.ts",
  "scripts": {
    "dev": "CLOUDFLARE_ENV=development react-router dev",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:smoke": "PLAYWRIGHT_RUN_SMOKE=1 pnpm test:e2e",
    "test:e2e:smoke:staging": "PLAYWRIGHT_RUN_SMOKE=1 E2E_BASE_URL=https://staging.sprintjam.co.uk pnpm test:e2e",
    "test:e2e:smoke:production": "PLAYWRIGHT_RUN_SMOKE=1 E2E_BASE_URL=https://sprintjam.co.uk pnpm test:e2e",
    "test:e2e:all": "PLAYWRIGHT_RUN_A11Y=1 pnpm test:e2e",
    "test:e2e:a11y": "PLAYWRIGHT_RUN_A11Y=1 pnpm test:e2e tests/e2e/a11y",
    "build": "react-router build",
    "build:staging": "CLOUDFLARE_ENV=staging react-router build",
    "deploy": "wrangler deploy",
    "deploy:staging": "wrangler deploy --env staging",
    "deploy:prod": "wrangler deploy",
    "typecheck": "react-router typegen && tsc -b --noEmit",
    "generate:types": "react-router typegen && wrangler types --include-runtime=false"
  },
  "dependencies": {
    "@base-ui/react": "^1.2.0",
    "@sentry/cloudflare": "^10.36.0",
    "@sentry/react": "^10.36.0",
    "@sprintjam/types": "workspace:*",
    "@sprintjam/utils": "workspace:*",
    "@strudel/web": "1.3.0",
    "@tailwindcss/typography": "0.5.19",
    "@tanstack/query-core": "5.100.9",
    "@tanstack/react-query": "5.100.9",
    "@tanstack/react-query-devtools": "5.100.9",
    "canvas-confetti": "1.9.4",
    "framer-motion": "12.23.26",
    "isbot": "^5.1.33",
    "lucide-react": "0.574.0",
    "qrcode.react": "4.2.0",
    "react": "19.2.5",
    "react-dom": "19.2.5",
    "react-router": "^7.13.1",
    "tailwindcss": "4.1.14",
    "zod": "4.3.5"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@cloudflare/vite-plugin": "1.35.0",
    "@cloudflare/workers-types": "4.20260115.0",
    "@playwright/test": "1.57.0",
    "@react-router/dev": "^7.13.1",
    "@tailwindcss/vite": "4.2.4",
    "@testing-library/react": "16.3.2",
    "@types/node": "25.0.3",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.2",
    "jsdom": "27.4.0",
    "typescript": "5.9.3",
    "vite": "7.3.2",
    "vitest": "4.0.16",
    "wrangler": "4.87.0"
  }
}
